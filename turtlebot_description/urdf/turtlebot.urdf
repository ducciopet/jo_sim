<?xml version="1.0" ?>
<robot name="turtlebot">

  <link name="base_footprint"/>

  <!-- base_joint z = wheel_radius so the robot sits on the ground -->
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 0.12" rpy="0 0 0"/>
  </joint>

  <!-- Body: 0.6m wide, 0.6m deep, 1.1m tall — top at ~1.22m from ground -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.55" rpy="0 0 0"/>
      <geometry>
        <box size="0.6 0.6 1.1"/>
      </geometry>
      <material name="light_black">
        <color rgba="0.4 0.4 0.4 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.55" rpy="0 0 0"/>
      <geometry>
        <box size="0.6 0.6 1.1"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.55" rpy="0 0 0"/>
      <mass value="20.0"/>
      <!-- box inertia: ixx=m/12*(y²+z²), iyy=m/12*(x²+z²), izz=m/12*(x²+y²) -->
      <inertia ixx="2.617" ixy="0.0" ixz="0.0"
               iyy="2.617" iyz="0.0" izz="1.200"/>
    </inertial>
  </link>

  <!-- wheel z = wheel_radius - base_joint_z = 0.12 - 0.12 = 0.0 -->
  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left_link"/>
    <origin xyz="0.0 0.38 0.0" rpy="-1.57 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.06" radius="0.12"/>
      </geometry>
      <material name="dark">
        <color rgba="0.3 0.3 0.3 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.06" radius="0.12"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="1.950e-03" ixy="0.0" ixz="0.0"
               iyy="1.950e-03" iyz="0.0" izz="3.600e-03"/>
    </inertial>
  </link>

  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_right_link"/>
    <origin xyz="0.0 -0.38 0.0" rpy="-1.57 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.06" radius="0.12"/>
      </geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.06" radius="0.12"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="1.950e-03" ixy="0.0" ixz="0.0"
               iyy="1.950e-03" iyz="0.0" izz="3.600e-03"/>
    </inertial>
  </link>

  <!-- front passive wheels — prevent forward tipping -->
  <!-- z=0 in base_link frame → wheel centre at 0.12m from ground = wheel_radius ✓ -->
  <joint name="wheel_front_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_front_left_link"/>
    <origin xyz="0.28 0.20 0.0" rpy="-1.57 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_front_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.12"/>
      </geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.12"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.1"/>
      <!-- cylinder: ixx=iyy=m/12*(3r²+L²), izz=m/2*r² -->
      <inertia ixx="3.73e-04" ixy="0.0" ixz="0.0"
               iyy="3.73e-04" iyz="0.0" izz="7.20e-04"/>
    </inertial>
  </link>

  <joint name="wheel_front_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_front_right_link"/>
    <origin xyz="0.28 -0.20 0.0" rpy="-1.57 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_front_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.12"/>
      </geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.12"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="3.73e-04" ixy="0.0" ixz="0.0"
               iyy="3.73e-04" iyz="0.0" izz="7.20e-04"/>
    </inertial>
  </link>

  <!-- caster sphere center at z = sphere_radius - base_joint_z = 0.02 - 0.12 = -0.10 -->
  <joint name="caster_back_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_back_link"/>
    <origin xyz="-0.28 0 -0.10" rpy="0 0 0"/>
  </joint>

  <link name="caster_back_link">
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="1.0e-04" ixy="0.0" ixz="0.0" iyy="1.0e-04" iyz="0.0" izz="1.0e-04"/>
    </inertial>
  </link>

  <!-- Front passive wheels: no lateral friction so turns are not resisted -->
  <gazebo reference="wheel_front_left_link">
    <mu>1.0</mu>
    <mu2>0.0</mu2>
  </gazebo>
  <gazebo reference="wheel_front_right_link">
    <mu>1.0</mu>
    <mu2>0.0</mu2>
  </gazebo>

  <!-- Gazebo Harmonic: diff drive plugin -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>wheel_left_joint</left_joint>
      <right_joint>wheel_right_joint</right_joint>
      <wheel_separation>0.76</wheel_separation>
      <wheel_radius>0.12</wheel_radius>
      <odom_publish_frequency>30</odom_publish_frequency>
      <topic>/model/turtlebot/cmd_vel</topic>
      <odom_topic>/model/turtlebot/odometry</odom_topic>
      <tf_topic>/model/turtlebot/tf</tf_topic>
      <frame_id>turtlebot/odom</frame_id>
      <child_frame_id>turtlebot/base_footprint</child_frame_id>
    </plugin>
  </gazebo>

  <!-- Gazebo Harmonic: joint state publisher -->
  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
      <topic>/model/turtlebot/joint_states</topic>
      <joint_name>wheel_left_joint</joint_name>
      <joint_name>wheel_right_joint</joint_name>
      <joint_name>wheel_front_left_joint</joint_name>
      <joint_name>wheel_front_right_joint</joint_name>
    </plugin>
  </gazebo>

  <!-- Ground-truth world-frame pose (reads physics ECM, not wheel integration) -->
  <gazebo>
    <plugin filename="gz-sim-odometry-publisher-system" name="gz::sim::systems::OdometryPublisher">
      <odom_frame>world</odom_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <topic>/model/turtlebot/world_odometry</topic>
      <odom_publish_frequency>30</odom_publish_frequency>
    </plugin>
  </gazebo>

</robot>
